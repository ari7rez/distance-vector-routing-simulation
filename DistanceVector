#!/usr/bin/env python3

# Distance Vector Routing Algorithm Implementation
# Assignment: Network Routing Protocols

def parse_nodes():
    """Read node names until START keyword"""
    nodes = []
    
    try:
        while True:
            line = input().strip()
            if line == "START":
                break
            nodes.append(line)
    except EOFError:
        print("Warning: Reached end of input while parsing nodes")
    
    return nodes
    pass

def parse_initial_topology():
    """Read topology links until UPDATE keyword"""
    topology = {}
    
    try:
        while True:
            line = input().strip()
            if line == "UPDATE":
                break
            
            # Parse "X Y 3" format
            parts = line.split()
            node1, node2, weight = parts[0], parts[1], int(parts[2])
            
            # Store bidirectional links
            if node1 not in topology:
                topology[node1] = {}
            if node2 not in topology:
                topology[node2] = {}
                
            topology[node1][node2] = weight
            topology[node2][node1] = weight
            
    except EOFError:
        print("Warning: Reached end of input while parsing topology")
    
    return topology
    pass

def parse_updates():
    """Read topology updates until END keyword"""
    updates = []
    
    try:
        while True:
            line = input().strip()
            if line == "END":
                break
            
            # Parse "X Y 3" or "X Y -1" format
            parts = line.split()
            node1, node2, weight = parts[0], parts[1], int(parts[2])
            updates.append((node1, node2, weight))
            
    except EOFError:
        print("Warning: Reached end of input while parsing updates")
    
    return updates
    pass
def initialize_distance_tables(nodes, topology):
    """Initialize distance tables for all nodes"""
    distance_tables = {}
    
    for node in nodes:
        distance_tables[node] = {}
        for dest in nodes:
            if dest != node:  # Don't need route to self
                distance_tables[node][dest] = {}
                for neighbor in nodes:
                    if neighbor != node:  # Don't route via self
                        # Check if neighbor is directly connected to current node
                        if neighbor in topology.get(node, {}):
                            # Direct neighbor - check if it connects to destination
                            if dest == neighbor:
                                # Direct route to neighbor
                                distance_tables[node][dest][neighbor] = topology[node][neighbor]
                            else:
                                # Route via neighbor to destination (unknown initially)
                                distance_tables[node][dest][neighbor] = float('inf')
                        else:
                            # Not a direct neighbor - can't route through it
                            distance_tables[node][dest][neighbor] = float('inf')
    
    return distance_tables

def print_distance_tables(distance_tables, nodes, time_step):
    """Print distance tables in required format"""
    for node in sorted(nodes):
        print(f"Distance Table of router {node} at t={time_step}:")
        
        other_nodes = sorted([n for n in nodes if n != node])
        
        # Print header row with exact spacing
        print("     ", end="")  # 5 spaces
        for neighbor in other_nodes:
            print(f"{neighbor:<4} ", end="")  # 4 chars + space
        print()
        
        # Print each destination row
        for dest in other_nodes:
            print(f"{dest:<4} ", end="")  # 4 chars + space
            for neighbor in other_nodes:
                if neighbor in distance_tables[node][dest]:
                    dist = distance_tables[node][dest][neighbor]
                    if dist == float('inf'):
                        print(f"{'INF':<4} ", end="")
                    else:
                        print(f"{dist:<4} ", end="")
                else:
                    print(f"{'INF':<4} ", end="")
            print()
        
        print()  # Blank line between tables

def run_dv_algorithm(nodes, topology, distance_tables, start_time=0):
    """Run Distance Vector algorithm until convergence"""
    time_step = start_time
    print_distance_tables(distance_tables, nodes, time_step)
    
    while True:
        time_step += 1
        
        # Store old tables for convergence check
        old_tables = {}
        for node in nodes:
            old_tables[node] = {}
            for dest in nodes:
                if dest != node:
                    old_tables[node][dest] = distance_tables[node][dest].copy()
        
        # Update distance tables using DV equation
        for node in nodes:
            for dest in nodes:
                if dest != node:
                    for neighbor in topology.get(node, {}):
                        if neighbor != dest:  # Don't route to dest via dest
                            # DV equation: min(current, cost_to_neighbor + neighbor_distance_to_dest)
                            current_dist = distance_tables[node][dest][neighbor]
                            neighbor_cost = topology[node][neighbor]
                            
                            # Find best distance from neighbor to dest
                            best_neighbor_dist = float('inf')
                            for via in old_tables[neighbor][dest]:
                                if old_tables[neighbor][dest][via] < best_neighbor_dist:  
                                    best_neighbor_dist = old_tables[neighbor][dest][via]
                            
                            new_dist = neighbor_cost + best_neighbor_dist
                            distance_tables[node][dest][neighbor] = min(current_dist, new_dist)
        
        print_distance_tables(distance_tables, nodes, time_step)
        
        # Check convergence (simplified for now)
        converged = True
        for node in nodes:
            for dest in nodes:
                if dest != node:
                    for neighbor in distance_tables[node][dest]:
                        if distance_tables[node][dest][neighbor] != old_tables[node][dest].get(neighbor, float('inf')):
                            converged = False
                            break
        
        if converged:
            routing_tables = generate_routing_tables(nodes, distance_tables)
            print_routing_tables(routing_tables, nodes)
            break
        
        if time_step > 20:  # Safety limit
            break
    return time_step
def generate_routing_tables(nodes, distance_tables):
    """Generate routing tables from distance tables"""
    routing_tables = {}
    
    for node in nodes:
        routing_tables[node] = {}
        for dest in nodes:
            if dest != node:
                # Find best route (minimum cost) to destination
                best_cost = float('inf')
                best_neighbor = None
                
                for neighbor in distance_tables[node][dest]:
                    cost = distance_tables[node][dest][neighbor]
                    if cost < best_cost:
                        best_cost = cost
                        best_neighbor = neighbor
                    elif cost == best_cost and neighbor < best_neighbor:
                        # Tie-breaking: alphabetical order
                        best_neighbor = neighbor
                
                if best_neighbor is not None and best_cost != float('inf'):
                    routing_tables[node][dest] = (best_neighbor, best_cost)
                else:
                    routing_tables[node][dest] = ('INF', 'INF')
    
    return routing_tables

def print_routing_tables(routing_tables, nodes):
    """Print routing tables in required format"""
    for node in sorted(nodes):
        for dest in sorted(nodes):
            if dest != node:
                next_hop, cost = routing_tables[node][dest]
                print(f"{dest},{next_hop},{cost}")
        print()  # Blank line between tables

def apply_topology_updates(topology, updates, nodes):
    """Apply topology updates including link removal (-1) and new links"""
    for node1, node2, weight in updates:
        # Add new nodes if they don't exist
        if node1 not in nodes:
            nodes.append(node1)
        if node2 not in nodes:
            nodes.append(node2)
            
        # Initialize topology entries if needed
        if node1 not in topology:
            topology[node1] = {}
        if node2 not in topology:
            topology[node2] = {}
            
        if weight == -1:
            # Remove link
            if node2 in topology[node1]:
                del topology[node1][node2]
            if node1 in topology[node2]:
                del topology[node2][node1]
        else:
            # Add or update link
            topology[node1][node2] = weight
            topology[node2][node1] = weight
    


def main():
    
    # Phase 1: Parse nodes and initial topology
    nodes = parse_nodes()
    topology = parse_initial_topology()
    
    # Phase 2: Run first DV algorithm (after UPDATE keyword)
    distance_tables = initialize_distance_tables(nodes, topology)
    final_time = run_dv_algorithm(nodes, topology, distance_tables, 0)
    
    # Phase 3: Parse updates and run second algorithm (after END keyword)
    updates = parse_updates()
    
    # Apply updates to topology if any exist
    if updates:
        apply_topology_updates(topology, updates, nodes)
        distance_tables = initialize_distance_tables(nodes, topology)
        run_dv_algorithm(nodes, topology, distance_tables, final_time)
    

if __name__ == "__main__":
    main()