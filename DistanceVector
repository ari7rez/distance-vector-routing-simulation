def parse_nodes():
    """Read node names until START keyword"""
    nodes = []
    print("Parsing nodes...")
    
    try:
        while True:
            line = input().strip()
            if line == "START":
                break
            nodes.append(line)
    except EOFError:
        print("Warning: Reached end of input while parsing nodes")
    
    print(f"Found nodes: {nodes}")
    return nodes
    pass

def parse_initial_topology():
    """Read topology links until UPDATE keyword"""
    topology = {}
    print("Parsing initial topology...")
    
    try:
        while True:
            line = input().strip()
            if line == "UPDATE":
                break
            
            # Parse "X Y 3" format
            parts = line.split()
            node1, node2, weight = parts[0], parts[1], int(parts[2])
            
            # Store bidirectional links
            if node1 not in topology:
                topology[node1] = {}
            if node2 not in topology:
                topology[node2] = {}
                
            topology[node1][node2] = weight
            topology[node2][node1] = weight
            
    except EOFError:
        print("Warning: Reached end of input while parsing topology")
    
    print(f"Parsed topology: {topology}")
    return topology
    pass

def parse_updates():
    """Read topology updates until END keyword"""
    updates = []
    print("Parsing updates...")
    
    try:
        while True:
            line = input().strip()
            if line == "END":
                break
            
            # Parse "X Y 3" or "X Y -1" format
            parts = line.split()
            node1, node2, weight = parts[0], parts[1], int(parts[2])
            updates.append((node1, node2, weight))
            
    except EOFError:
        print("Warning: Reached end of input while parsing updates")
    
    print(f"Parsed updates: {updates}")
    return updates
    pass

def main():
    print("Distance Vector Algorithm Starting...")
    
    # Three-phase input parsing
    nodes = parse_nodes()
    topology = parse_initial_topology()
    updates = parse_updates()
    
    print("Input parsing complete")

if __name__ == "__main__":
    main()
